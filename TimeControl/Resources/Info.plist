<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <!-- Required for Google Sign-In — replace with your reversed client ID from GoogleService-Info.plist -->
            <key>CFBundleURLSchemes</key>
            <array>
                <string>com.googleusercontent.apps.YOUR_CLIENT_ID_REVERSED</string>
            </array>
        </dict>
    </array>
    <key>NSFaceIDUsageDescription</key>
    <string>Used to authenticate your account.</string>
    <key>NSUserTrackingUsageDescription</key>
    <string>TimeControl uses screen time data only to show it to friends you choose.</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>processing</string>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.timecontrol.syncscreentime</string>
    </array>
</dict>
</plist>
